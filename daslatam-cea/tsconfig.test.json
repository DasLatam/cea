{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "preserve",
    "strict": false,
    "noEmit": true,
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {"@/*": ["./*"]},
    "skipLibCheck": true,
    "noResolve": false
  },
  "include": ["./app/**/*.tsx", "./components/**/*.tsx", "./lib/**/*.ts", "./test-stubs.d.ts"]
}
